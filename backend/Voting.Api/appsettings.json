{
  "ConnectionStrings": {
    "Default": "Data Source=voting.db"
  },
  "Jwt": {
    "Issuer": "Voting.Api",
    "Audience": "Voting.Frontend",
    "VoterTokenMinutes": 30,
    "AdminTokenHours": 6
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173"]
  },
  "Otp": {
    "ExpiryMinutes": 5,
    "MaxAttempts": 5
  },
  "Election": {
    "TimeZone": "Asia/Dhaka"
  },
  "Seed": {
    "RunOnStartup": true
  },
  "Email": {
    "Provider": "Smtp",
    "SenderEmail": "",
    "SenderName": "",
    "SmtpHost": "",
    "SmtpPort": 587,
    "SmtpUsername": "",
    "SmtpPassword": "",
    "SmtpUseStartTls": true
  }
}
