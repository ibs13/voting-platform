# =========================
# Backend
# =========================

ASPNETCORE_ENVIRONMENT=Production

# App URL binding inside container/platform
ASPNETCORE_URLS=http://+:8080

# Database
ConnectionStrings__Default=Host=YOUR_DB_HOST;Port=5432;Database=YOUR_DB_NAME;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD

# JWT
Jwt__Key=YOUR_LONG_RANDOM_JWT_KEY_AT_LEAST_32_BYTES
Jwt__Issuer=Voting.Api
Jwt__Audience=Voting.Frontend
Jwt__VoterTokenMinutes=30
Jwt__AdminTokenHours=6

# CORS
Cors__AllowedOrigins__0=https://your-frontend-domain.com

# OTP
Otp__ExpiryMinutes=5
Otp__MaxAttempts=5

# Election
Election__TimeZone=Asia/Dhaka

# Seed
Seed__RunOnStartup=false

# Email
Email__Provider=Smtp
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__SmtpUsername=your-email@gmail.com
Email__SmtpPassword=your-app-password
Email__SenderEmail=your-email@gmail.com
Email__SenderName=Voting Platform
Email__SmtpUseStartTls=true